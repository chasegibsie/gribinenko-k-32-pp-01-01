<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0" style="-fx-background-color: #E6E4DA;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.kartonplus.controller.MaterialsController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30"/>
    </padding>

    <Label text="Сырье на складе" textFill="#2E2E2E">
        <font>
            <Font name="Arial" size="28.0"/>
        </font>
    </Label>

    <HBox spacing="10.0">
        <Button fx:id="addButton" onAction="#handleAddMaterial" text="Добавить материал"
                style="-fx-background-color: #6B7B84; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 25; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="refreshButton" onAction="#handleRefresh" text="Обновить"
                style="-fx-background-color: #A9ACA9; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12 25; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" visible="false" wrapText="true" maxWidth="400">
            <font><Font name="Arial" size="14.0"/></font>
        </Label>
    </HBox>

    <TableView fx:id="materialsTable" style="-fx-background-color: white; -fx-border-color: #A9ACA9; -fx-border-radius: 5;">
        <columns>
            <TableColumn fx:id="nameCol" text="Наименование" prefWidth="200"/>
            <TableColumn fx:id="typeCol" text="Тип" prefWidth="100"/>
            <TableColumn fx:id="quantityCol" text="Количество (тонн)" prefWidth="150"/>
            <TableColumn fx:id="rollsCol" text="Рулонов" prefWidth="100"/>
            <TableColumn fx:id="dailyConsumptionCol" text="Дневной расход" prefWidth="130"/>
            <TableColumn fx:id="daysCol" text="Осталось дней" prefWidth="120"/>
            <TableColumn fx:id="supplierCol" text="Поставщик" prefWidth="150"/>
            <TableColumn fx:id="actionsCol" text="Действия" prefWidth="150"/>
        </columns>
    </TableView>
</VBox>